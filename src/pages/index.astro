---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroText from '../components/home/HeroText.svelte';
import ScrollHint from '../components/home/ScrollHint.svelte';
---

<BaseLayout title="Atelier — Charles" description="Portfolio of Charles — developer, musician, builder, and creative." isHome>
  <!--
    client:only="svelte" — skips SSR (required: these use window / onMount).
    HeroText + ScrollHint live inside <main> (z-index:1, pointer-events:none).
    DotIndicator is rendered directly in BaseLayout OUTSIDE main so it sits
    above the scroll-container and receives click events.
  -->
  <HeroText client:only="svelte" />
  <ScrollHint client:only="svelte" />
</BaseLayout>
