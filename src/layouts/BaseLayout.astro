---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import Navbar from '../components/shared/Navbar.astro';
import DotIndicator from '../components/home/DotIndicator.svelte';
import { SECTIONS } from '../components/home/sections';

interface Props {
  title?: string;
  description?: string;
  /** Set to true for the home page (enables scroll-container, dot indicator, grid morphing) */
  isHome?: boolean;
}
const {
  title = 'Atelier — Charles',
  description = 'Portfolio of Charles — developer, musician, and creative.',
  isHome = false,
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={[{ 'page-home': isHome }]}>
    <!-- z-index 0: WebGL grid canvas (background on all pages) -->
    <canvas
      id="grid-canvas"
      style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"
      aria-hidden="true"
    ></canvas>

    <!-- z-index 100: Navbar -->
    <Navbar />

    {isHome && (
      <main style="position:fixed;inset:0;z-index:1;pointer-events:none;">
        <slot />
      </main>
    )}

    {isHome && <DotIndicator client:only="svelte" />}

    {isHome && (
      <div class="scroll-container" aria-hidden="true">
        {SECTIONS.map((s) => (
          <div
            class="scroll-section"
            data-section-id={String(s.id)}
            data-grid-state={s.gridState}
          />
        ))}
      </div>
    )}

    {!isHome && (
      <main class="page-content">
        <slot />
      </main>
    )}

    <!-- Grid engine bootstrap (runs client-side only) -->
    <script>
      import { GridEngine } from '../lib/grid/GridEngine';
      import { AmbientAnimation } from '../lib/grid/AmbientAnimation';
      import { ScrollOrchestrator } from '../lib/grid/ScrollOrchestrator';
      import { SECTIONS } from '../components/home/sections';

      const canvas = document.getElementById('grid-canvas') as HTMLCanvasElement;
      if (canvas) {
        const engine = new GridEngine(canvas);
        const ambient = new AmbientAnimation(engine);

        ambient.start();

        // Home page: scroll-mapped morphing
        const scrollContainer = document.querySelector('.scroll-container') as HTMLElement | null;
        if (scrollContainer) {
          const orchestrator = new ScrollOrchestrator(engine, SECTIONS);
          orchestrator.init(scrollContainer);

          window.addEventListener('atelier:jump-to-section', (e) => {
            const detail = (e as CustomEvent<{ index: number }>).detail;
            orchestrator.goToSection(detail.index);
          });
        }

        document.addEventListener('mousemove', (e) => {
          engine.setCursor(
            (e.clientX / window.innerWidth) * 2 - 1,
            -((e.clientY / window.innerHeight) * 2 - 1),
          );
        });
      }
    </script>
  </body>
</html>
